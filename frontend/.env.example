# Sahan Cargo Frontend – Environment Variables Template
# Copy this file to .env and fill in the values

# Backend API base URL
# NOTE: Do NOT add /api at the end — axios.js appends /api automatically
# Local development:
VITE_API_URL=http://localhost:5000

# Production (set in Netlify dashboard, no /api suffix):
# VITE_API_URL=https://sahan-cargo-backend.onrender.com
