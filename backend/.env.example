# Backend Environment Variables
# Copy this to backend/.env for local development
# Set these in your Render dashboard for production

PORT=5000
NODE_ENV=development

# Database (local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=sahan_cargo

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Frontend URL (for CORS) — set to your Netlify URL in production
FRONTEND_URL=http://localhost:5173
